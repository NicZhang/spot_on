.page-login {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffffff 0%, #f5f5f5 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
  box-sizing: border-box;
}

/* ========== Logo 区域 ========== */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 260rpx;
  opacity: 0;
  transform: translateY(40rpx);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.logo-area--visible {
  opacity: 1;
  transform: translateY(0);
}

.logo-box {
  width: 192rpx;
  height: 192rpx;
  border-radius: 40rpx;
  background: #1f2329;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  font-size: 72rpx;
  font-weight: 800;
  font-style: italic;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.app-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1f2329;
  margin-top: 40rpx;
  letter-spacing: 2rpx;
}

.app-subtitle {
  font-size: 26rpx;
  color: #8f959e;
  margin-top: 12rpx;
}

/* ========== 按钮区域 ========== */
.btn-area {
  width: 100%;
  margin-top: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0;
  transform: translateY(30rpx);
  transition: opacity 0.6s ease 0.3s, transform 0.6s ease 0.3s;
}

.btn-area--visible {
  opacity: 1;
  transform: translateY(0);
}

/* 微信登录按钮 */
.wx-login-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.35);
}

.wx-login-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-icon {
  flex-shrink: 0;
}

.wx-login-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 手机号登录按钮 */
.phone-login-btn {
  margin-top: 32rpx;
  padding: 16rpx 40rpx;
}

.phone-login-btn:active {
  opacity: 0.6;
}

.phone-login-text {
  font-size: 28rpx;
  color: #646a73;
}

/* ========== 用户协议 ========== */
.agreement-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 60rpx calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: center;
}

.agreement-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.agreement-row--shake {
  animation: shake 0.4s ease;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-12rpx); }
  40% { transform: translateX(12rpx); }
  60% { transform: translateX(-8rpx); }
  80% { transform: translateX(8rpx); }
}

.agreement-text-wrap {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.agreement-text {
  font-size: 24rpx;
  color: #8f959e;
}

.agreement-link {
  font-size: 24rpx;
  color: #07c160;
}

.agreement-link:active {
  opacity: 0.6;
}
