<view class="page-container">
  <!-- Tab 切换 -->
  <van-tabs
    active="{{ activeTab }}"
    bind:change="onTabChange"
    color="#07c160"
    title-active-color="#07c160"
    title-inactive-color="#999999"
    line-width="60rpx"
    sticky
  >
    <van-tab title="即将开赛"></van-tab>
    <van-tab title="已结束"></van-tab>
  </van-tabs>

  <!-- Loading 骨架 -->
  <view class="skeleton-wrap" wx:if="{{ loading }}">
    <view class="skeleton-card" wx:for="{{ [1, 2, 3] }}" wx:key="*this">
      <view class="skeleton-line skeleton-line-short"></view>
      <view class="skeleton-line skeleton-line-long"></view>
      <view class="skeleton-line skeleton-line-medium"></view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-wrap" wx:elif="{{ isEmpty }}">
    <van-empty
      image="search"
      description="{{ activeTab === 0 ? '暂无赛程安排' : '暂无历史赛程' }}"
    />
    <text class="empty-sub" wx:if="{{ activeTab === 0 }}">去约球大厅发起一场比赛吧</text>
  </view>

  <!-- 赛程卡片列表 -->
  <view class="match-list" wx:else>
    <view
      class="match-card"
      wx:for="{{ matchList }}"
      wx:key="id"
      data-id="{{ item.id }}"
      bindtap="onCardTap"
    >
      <!-- 左侧色条 -->
      <view class="card-border" style="background-color: {{ item.borderColor }};"></view>

      <view class="card-body">
        <!-- 第一行：日期 + 状态 -->
        <view class="card-header">
          <view class="date-area">
            <text class="date-month-day">{{ item.month }}/{{ item.day }}</text>
            <text class="date-weekday">{{ item.weekday }}</text>
            <text class="date-time">{{ item.time }}</text>
          </view>
          <view class="status-badge" style="background-color: {{ item.statusBgColor }}; color: {{ item.statusColor }};">
            <text class="status-text">{{ item.statusText }}</text>
          </view>
        </view>

        <!-- 第二行：对阵信息 -->
        <view class="versus-area">
          <view class="opponent-info">
            <text class="vs-label">VS</text>
            <image
              class="opponent-logo"
              src="{{ item.opponentLogo }}"
              mode="aspectFill"
              wx:if="{{ item.opponentLogo }}"
            />
            <view class="opponent-logo-placeholder" wx:else>
              <van-icon name="team" color="#cccccc" size="36rpx" />
            </view>
            <text class="opponent-name">{{ item.opponentName }}</text>
          </view>
          <!-- 比分（已结束/待确认状态显示） -->
          <view class="score-area" wx:if="{{ item.showScore }}">
            <text class="score-text">{{ item.hostTeamScore }} : {{ item.guestTeamScore }}</text>
          </view>
        </view>

        <!-- 第三行：赛制 + 地点 + 费用 -->
        <view class="card-footer">
          <view class="info-tags">
            <van-tag plain type="primary" custom-class="format-tag">{{ item.format }}</van-tag>
            <view class="location-info">
              <van-icon name="location-o" size="24rpx" color="#999999" />
              <text class="location-text">{{ item.location }}</text>
            </view>
          </view>
          <view class="fee-area">
            <text class="fee-label">人均</text>
            <text class="fee-value">{{ item.feePerPlayer }}</text>
            <text class="fee-unit">元</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部加载更多 -->
    <view class="load-more" wx:if="{{ loadingMore }}">
      <van-loading size="24rpx" color="#07c160">加载中...</van-loading>
    </view>
    <view class="no-more" wx:elif="{{ noMore && matchList.length > 0 }}">
      <text class="no-more-text">没有更多了</text>
    </view>
  </view>

  <!-- FAB 发起约球 -->
  <view class="fab-btn" bindtap="onCreateTap">
    <van-icon name="plus" color="#ffffff" size="48rpx" />
  </view>
</view>
