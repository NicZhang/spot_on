.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 160rpx;
}

/* ========== 骨架屏 ========== */
.skeleton-wrap {
  padding: 24rpx 30rpx;
}

.skeleton-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.skeleton-line {
  height: 28rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 400% 100%;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  animation: skeleton-loading 1.5s ease infinite;
}

.skeleton-line-short {
  width: 40%;
}

.skeleton-line-long {
  width: 90%;
}

.skeleton-line-medium {
  width: 65%;
}

@keyframes skeleton-loading {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}

/* ========== 空状态 ========== */
.empty-wrap {
  padding-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-sub {
  font-size: 24rpx;
  color: #bbbbbb;
  margin-top: 12rpx;
}

/* ========== 赛程卡片列表 ========== */
.match-list {
  padding: 24rpx 30rpx 0;
}

.match-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: row;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-border {
  width: 6rpx;
  flex-shrink: 0;
}

.card-body {
  flex: 1;
  padding: 28rpx 28rpx 24rpx 24rpx;
  min-width: 0;
}

/* ===== 卡片头部：日期 + 状态 ===== */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.date-area {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.date-month-day {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2329;
}

.date-weekday {
  font-size: 24rpx;
  color: #666666;
}

.date-time {
  font-size: 24rpx;
  color: #999999;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.status-text {
  font-size: 22rpx;
  font-weight: 600;
}

/* ===== 对阵信息 ===== */
.versus-area {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.opponent-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.vs-label {
  font-size: 28rpx;
  font-weight: 800;
  color: #cccccc;
  margin-right: 4rpx;
}

.opponent-logo {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  flex-shrink: 0;
}

.opponent-logo-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.opponent-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score-area {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.score-text {
  font-size: 40rpx;
  font-weight: 800;
  color: #1f2329;
  font-family: "DIN Alternate", "Helvetica Neue", sans-serif;
  letter-spacing: 4rpx;
}

/* ===== 卡片底部：赛制 + 地点 + 费用 ===== */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1px solid #f0f0f0;
}

.info-tags {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.format-tag {
  flex-shrink: 0;
}

.location-info {
  display: flex;
  align-items: center;
  gap: 4rpx;
  min-width: 0;
  flex: 1;
}

.location-text {
  font-size: 24rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fee-area {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.fee-label {
  font-size: 22rpx;
  color: #999999;
}

.fee-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff6f00;
  font-family: "DIN Alternate", "Helvetica Neue", sans-serif;
}

.fee-unit {
  font-size: 22rpx;
  color: #999999;
}

/* ========== 底部加载 ========== */
.load-more {
  display: flex;
  justify-content: center;
  padding: 24rpx 0;
}

.no-more {
  display: flex;
  justify-content: center;
  padding: 24rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #cccccc;
}

/* ========== FAB 按钮 ========== */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background-color: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.4);
  z-index: 100;
  transition: transform 0.15s ease;
}

.fab-btn:active {
  transform: scale(0.92);
}
