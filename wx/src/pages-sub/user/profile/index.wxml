<!-- 队员资料编辑页 -->
<view class="page" wx:if="{{!loading && player}}">
  <!-- 头像区 -->
  <view class="avatar-section">
    <view class="avatar-wrapper" bindtap="onChangeAvatar">
      <image class="avatar-image" src="{{avatar}}" mode="aspectFill" wx:if="{{avatar}}" />
      <view class="avatar-placeholder" wx:else>
        <van-icon name="contact" size="80rpx" color="#ccc" />
      </view>
      <view class="camera-badge">
        <van-icon name="photograph" size="28rpx" color="#fff" />
      </view>
    </view>
  </view>

  <!-- 统计展示栏 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value">{{stats.goals}}</text>
      <text class="stat-label">进球</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.assists}}</text>
      <text class="stat-label">助攻</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value stat-mvp">{{stats.mvpCount}}</text>
      <text class="stat-label">MVP</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="section-card">
    <view class="section-title">
      <text class="section-title-text">基本信息</text>
    </view>
    <van-field
      label="姓名/昵称"
      placeholder="请输入姓名"
      value="{{name}}"
      bind:change="onNameInput"
    />
    <van-field
      label="球衣号码"
      type="digit"
      placeholder="请输入号码"
      value="{{number}}"
      bind:change="onNumberInput"
    />
    <view class="form-row">
      <text class="form-label">位置</text>
      <view class="btn-group">
        <view
          wx:for="{{positionOptions}}"
          wx:key="*this"
          class="btn-item {{position === item ? 'btn-active' : ''}}"
          data-value="{{item}}"
          bindtap="onSelectPosition"
        >
          <text class="btn-text">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 运动资料 -->
  <view class="section-card">
    <view class="section-title">
      <text class="section-title-text">运动资料</text>
    </view>
    <view class="form-row">
      <text class="form-label">水平</text>
      <view class="btn-group">
        <view
          wx:for="{{levelOptions}}"
          wx:key="*this"
          class="btn-item {{level === item ? 'btn-active' : ''}}"
          data-value="{{item}}"
          bindtap="onSelectLevel"
        >
          <text class="btn-text">{{item}}</text>
        </view>
      </view>
    </view>
    <van-field
      label="身高"
      type="digit"
      placeholder="请输入身高"
      value="{{height}}"
      bind:change="onHeightInput"
    >
      <text slot="right-icon" class="unit-text">cm</text>
    </van-field>
    <van-field
      label="体重"
      type="digit"
      placeholder="请输入体重"
      value="{{weight}}"
      bind:change="onWeightInput"
    >
      <text slot="right-icon" class="unit-text">kg</text>
    </van-field>
    <view class="form-row">
      <text class="form-label">惯用脚</text>
      <view class="btn-group">
        <view
          wx:for="{{strongFootOptions}}"
          wx:key="value"
          class="btn-item {{strongFoot === item.value ? 'btn-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSelectStrongFoot"
        >
          <text class="btn-text">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="bottom-bar">
    <van-button
      type="primary"
      block
      round
      color="#07c160"
      loading="{{submitting}}"
      disabled="{{submitting}}"
      bindtap="onSave"
    >保存</van-button>
  </view>
</view>

<!-- Loading -->
<view class="loading-container" wx:if="{{loading}}">
  <van-icon name="loading" size="48rpx" color="#999" />
  <text class="loading-text">加载中...</text>
</view>

<!-- Empty -->
<view class="empty-container" wx:if="{{!loading && !player}}">
  <van-icon name="info-o" size="80rpx" color="#ccc" />
  <text class="empty-text">未找到队员信息</text>
</view>
