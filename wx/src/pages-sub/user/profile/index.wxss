.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* --- Avatar Section --- */
.avatar-section {
  display: flex;
  justify-content: center;
  padding: 48rpx 0 32rpx;
  background: #ffffff;
  margin: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.avatar-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.avatar-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.avatar-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: #f5f5f5;
  border: 4rpx dashed #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #ffffff;
}

/* --- Stats Card --- */
.stats-card {
  background: #ffffff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2329;
}

.stat-mvp {
  color: #ff9500;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1px;
  height: 60rpx;
  background: #eee;
}

/* --- Section Card --- */
.section-card {
  background: #ffffff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  margin-bottom: 20rpx;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}

/* --- Form Row & Button Group --- */
.form-row {
  padding: 20rpx 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.btn-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.btn-item {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  border: 2rpx solid #eee;
}

.btn-item.btn-active {
  background: rgba(7, 193, 96, 0.1);
  border-color: #07c160;
}

.btn-text {
  font-size: 26rpx;
  color: #666;
}

.btn-active .btn-text {
  color: #07c160;
  font-weight: 600;
}

.unit-text {
  font-size: 26rpx;
  color: #999;
}

/* --- Bottom Bar --- */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* --- Loading & Empty --- */
.loading-container,
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
}

.loading-text,
.empty-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}
