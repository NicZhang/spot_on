.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* --- Versus Card --- */
.versus-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  padding: 48rpx 32rpx;
  margin: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.team-side {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.team-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.placeholder-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx dashed #ccc;
}

.placeholder-text {
  font-size: 48rpx;
  color: #ccc;
  font-weight: 600;
}

.team-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
  margin-top: 16rpx;
  text-align: center;
}

.placeholder-name {
  color: #999;
  font-weight: 400;
}

.team-credit {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.credit-label {
  font-size: 22rpx;
  color: #999;
  margin-right: 8rpx;
}

.credit-value {
  font-size: 24rpx;
  color: #07c160;
  font-weight: 600;
}

.versus-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24rpx;
}

.versus-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #1f2329;
}

.versus-status {
  font-size: 22rpx;
  color: #ff9500;
  margin-top: 8rpx;
}

.versus-status.matched {
  color: #07c160;
}

.versus-status.finished {
  color: #999;
}

.versus-status.cancelled {
  color: #ee0a24;
}

/* --- Info Card --- */
.info-card {
  background: #ffffff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  margin-bottom: 24rpx;
}

.card-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  margin-left: 12rpx;
  width: 100rpx;
}

.info-value {
  font-size: 26rpx;
  color: #1f2329;
  flex: 1;
}

/* --- Cost --- */
.cost-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.cost-label {
  font-size: 26rpx;
  color: #666;
}

.cost-value {
  font-size: 26rpx;
  color: #1f2329;
}

.cost-divider {
  height: 1px;
  background: #eee;
  margin: 16rpx 0;
}

.total-row {
  padding-top: 16rpx;
}

.total-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
}

.total-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #ee0a24;
}

/* --- Jersey --- */
.jersey-row {
  display: flex;
  align-items: center;
}

.color-block {
  width: 48rpx;
  height: 48rpx;
  border-radius: 8rpx;
  border: 2rpx solid #eee;
  margin-right: 16rpx;
}

.jersey-text {
  font-size: 26rpx;
  color: #666;
}

/* --- Tags --- */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.amenity-tag {
  margin-right: 0 !important;
}

/* --- Memo --- */
.memo-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* --- Bottom Bar --- */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* --- Loading & Empty --- */
.loading-container,
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
}

.loading-text,
.empty-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}
