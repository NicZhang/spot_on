<!-- 发起约球页 -->
<view class="page">
  <!-- 比赛时间 -->
  <view class="section-card">
    <view class="section-title">
      <text class="section-title-text">比赛时间</text>
    </view>
    <van-cell title="日期" value="{{dateText || '请选择'}}" is-link bindtap="onShowDatePicker" />
    <van-cell title="时间" value="{{timeText || '请选择'}}" is-link bindtap="onShowTimePicker" />

    <view class="form-row">
      <text class="form-label">时长</text>
      <view class="btn-group">
        <view
          wx:for="{{durationOptions}}"
          wx:key="*this"
          class="btn-item {{duration === item ? 'btn-active' : ''}}"
          data-value="{{item}}"
          bindtap="onSelectDuration"
        >
          <text class="btn-text">{{item}}分钟</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 地点 -->
  <view class="section-card">
    <view class="section-title">
      <text class="section-title-text">比赛地点</text>
    </view>
    <van-field
      label="地点"
      placeholder="请输入球场名称或地址"
      bind:change="onLocationInput"
      value="{{location}}"
    />
  </view>

  <!-- 比赛设置 -->
  <view class="section-card">
    <view class="section-title">
      <text class="section-title-text">比赛设置</text>
    </view>
    <view class="form-row">
      <text class="form-label">赛制</text>
      <view class="btn-group">
        <view
          wx:for="{{formatOptions}}"
          wx:key="*this"
          class="btn-item {{format === item ? 'btn-active' : ''}}"
          data-value="{{item}}"
          bindtap="onSelectFormat"
        >
          <text class="btn-text">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="form-row">
      <text class="form-label">强度</text>
      <view class="btn-group">
        <view
          wx:for="{{intensityOptions}}"
          wx:key="*this"
          class="btn-item {{intensity === item ? 'btn-active' : ''}}"
          data-value="{{item}}"
          bindtap="onSelectIntensity"
        >
          <text class="btn-text">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="form-row">
      <text class="form-label">性别要求</text>
      <view class="btn-group">
        <view
          wx:for="{{genderOptions}}"
          wx:key="value"
          class="btn-item {{genderReq === item.value ? 'btn-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSelectGender"
        >
          <text class="btn-text">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 费用明细 -->
  <view class="section-card">
    <view class="section-title">
      <text class="section-title-text">费用明细</text>
    </view>
    <van-field
      label="场地费"
      type="digit"
      placeholder="0"
      value="{{pitchFee}}"
      bind:change="onPitchFeeInput"
    >
      <text slot="right-icon" class="unit-text">元</text>
    </van-field>
    <van-field
      label="裁判费"
      type="digit"
      placeholder="0"
      value="{{refereeFee}}"
      bind:change="onRefereeFeeInput"
    >
      <text slot="right-icon" class="unit-text">元</text>
    </van-field>
    <van-field
      label="水费"
      type="digit"
      placeholder="0"
      value="{{waterFee}}"
      bind:change="onWaterFeeInput"
    >
      <text slot="right-icon" class="unit-text">元</text>
    </van-field>
    <view class="total-row">
      <text class="total-label">总费用</text>
      <text class="total-value">¥{{totalPrice}}</text>
    </view>
  </view>

  <!-- 球衣颜色 -->
  <view class="section-card">
    <view class="section-title">
      <text class="section-title-text">球衣颜色</text>
    </view>
    <view class="color-select-row" bindtap="onShowColorPicker">
      <view class="color-preview" style="background-color: {{jerseyColor}};"></view>
      <text class="color-text">点击选择颜色</text>
      <van-icon name="arrow" size="28rpx" color="#999" />
    </view>
  </view>

  <!-- 球场设施 -->
  <view class="section-card">
    <view class="section-title">
      <text class="section-title-text">球场设施</text>
    </view>
    <view class="amenity-grid">
      <view
        wx:for="{{amenityOptions}}"
        wx:key="*this"
        class="amenity-item {{selectedAmenities.indexOf(item) >= 0 ? 'amenity-active' : ''}}"
        data-item="{{item}}"
        bindtap="onToggleAmenity"
      >
        <text class="amenity-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section-card">
    <view class="section-title">
      <text class="section-title-text">备注</text>
    </view>
    <van-field
      type="textarea"
      placeholder="补充说明（选填）"
      autosize="{{ { maxHeight: 200 } }}"
      value="{{memo}}"
      bind:change="onMemoInput"
    />
  </view>

  <!-- 底部提交 -->
  <view class="bottom-bar">
    <van-button
      type="primary"
      block
      round
      color="#07c160"
      loading="{{submitting}}"
      disabled="{{submitting}}"
      bindtap="onSubmit"
    >发布约球</van-button>
  </view>
</view>

<!-- Date Picker Popup -->
<van-popup show="{{showDatePicker}}" position="bottom" round bind:close="onCloseDatePicker">
  <van-datetime-picker
    type="date"
    value="{{currentDate}}"
    min-date="{{minDate}}"
    max-date="{{maxDate}}"
    bind:confirm="onDateConfirm"
    bind:cancel="onCloseDatePicker"
  />
</van-popup>

<!-- Time Picker Popup -->
<van-popup show="{{showTimePicker}}" position="bottom" round bind:close="onCloseTimePicker">
  <van-datetime-picker
    type="time"
    value="{{timeValue}}"
    bind:confirm="onTimeConfirm"
    bind:cancel="onCloseTimePicker"
  />
</van-popup>

<!-- Color Picker Popup -->
<van-popup show="{{showColorPicker}}" position="bottom" round bind:close="onCloseColorPicker">
  <view class="color-picker-panel">
    <view class="color-picker-title">
      <text class="color-picker-title-text">选择球衣颜色</text>
    </view>
    <view class="color-grid">
      <view
        wx:for="{{colorOptions}}"
        wx:key="color"
        class="color-grid-item"
        data-color="{{item.color}}"
        bindtap="onSelectColor"
      >
        <view
          class="color-circle {{jerseyColor === item.color ? 'color-selected' : ''}}"
          style="background-color: {{item.color}};"
        ></view>
        <text class="color-name">{{item.name}}</text>
      </view>
    </view>
  </view>
</van-popup>
